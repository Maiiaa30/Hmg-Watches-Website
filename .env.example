# Supabase — obtém em app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase DB — obtém em Settings → Database → Connection string → URI
# Formato: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=

# Google Gemini — chave gratuita em aistudio.google.com (geração de blog)
GEMINI_API_KEY=
# Opcional: modelo Gemini (default: gemini-2.5-flash)
GEMINI_MODEL=

# Anthropic — (opcional, já não usado para o blog)
ANTHROPIC_API_KEY=

# Telegram — cria o bot via @BotFather; CHAT_ID é o teu grupo/canal
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Upstash Redis — obtém em console.upstash.com (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend — obtém em resend.com (email transacional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@seudominio.com

# Metals.dev — obtém em metals.dev (free tier: 100 pedidos/mês)
METALS_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron Jobs — gera com: openssl rand -hex 32
CRON_SECRET=
